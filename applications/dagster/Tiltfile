# Dagster Platform - Shared orchestration webserver + daemon + postgres
load('ext://uibutton', 'cmd_button')
load('ext://k8s_attach', 'k8s_attach')

allow_k8s_contexts('admin@catalyst-cluster')
ns, label = 'dagster', '2-infra-platform'

# Postgres
k8s_attach('dagster-postgres', 'deployment/dagster-postgres', namespace=ns,
           labels=[label],
           links=[])

# Webserver
k8s_attach('dagster-webserver', 'deployment/dagster-webserver', namespace=ns,
           port_forwards=['3000:3000'],
           labels=[label],
           links=[link('http://dagster.talos00', 'Dagster (Ingress)'),
                  link('http://localhost:3000', 'Local')])

# Daemon
k8s_attach('dagster-daemon', 'deployment/dagster-daemon', namespace=ns,
           labels=[label],
           links=[])

# --- Buttons ---
cmd_button(name='btn-dagster-status', resource='dagster-webserver',
    text='Status', icon_name='info',
    argv=['sh', '-c', 'echo "=== Pods ===" && kubectl get pods -n dagster -owide && echo && echo "=== PVCs ===" && kubectl get pvc -n dagster'])

cmd_button(name='btn-dagster-logs-web', resource='dagster-webserver',
    text='Logs', icon_name='description',
    argv=['sh', '-c', 'echo "=== Webserver Logs (last 50) ===" && kubectl logs -n dagster deploy/dagster-webserver --tail=50'])

cmd_button(name='btn-dagster-logs-daemon', resource='dagster-daemon',
    text='Logs', icon_name='description',
    argv=['sh', '-c', 'echo "=== Daemon Logs (last 50) ===" && kubectl logs -n dagster deploy/dagster-daemon --tail=50'])

cmd_button(name='btn-dagster-restart-web', resource='dagster-webserver',
    text='Restart', icon_name='refresh', requires_confirmation=True,
    argv=['sh', '-c', 'echo "Restarting webserver..." && kubectl rollout restart deploy/dagster-webserver -n dagster && kubectl rollout status deploy/dagster-webserver -n dagster --timeout=120s && echo "Done"'])

cmd_button(name='btn-dagster-restart-daemon', resource='dagster-daemon',
    text='Restart', icon_name='refresh', requires_confirmation=True,
    argv=['sh', '-c', 'echo "Restarting daemon..." && kubectl rollout restart deploy/dagster-daemon -n dagster && kubectl rollout status deploy/dagster-daemon -n dagster --timeout=120s && echo "Done"'])

cmd_button(name='btn-dagster-dashboard', resource='dagster-webserver',
    text='Dashboard', icon_name='dashboard',
    argv=['sh', '-c', './dashboard.sh 2>/dev/null || echo "Dashboard not found"'])
