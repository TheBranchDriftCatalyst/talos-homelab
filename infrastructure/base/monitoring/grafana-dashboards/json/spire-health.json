  },
  "description": "SPIRE health dashboard. Filed 2026-05-27 during cilium-agent meltdown investigation. cilium has authentication.mutual.spire.enabled=true. spire-server has been 0/1 Ready for 20+ days, causing every cilium-agent pod to log 'SPIRE admin socket does not exist' warnings every ~10s. Use this dashboard to track SPIRE readiness, socket-warning frequency, and cilium mesh-auth correlation with meltdown events.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "includeVars": false, "keepTime": false, "tags": [], "targetBlank": true, "title": "Talos Cluster Debug", "tooltip": "Sibling dashboard for cluster-wide meltdown debugging", "type": "link", "url": "/d/talos-cluster-debug"},
    {"asDropdown": false, "icon": "external link", "includeVars": false, "keepTime": false, "tags": [], "targetBlank": true, "title": "Cilium SPIRE docs", "tooltip": "", "type": "link", "url": "https://docs.cilium.io/en/stable/network/servicemesh/mutual-authentication/mutual-authentication/"}
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "SPIRE Identity Plane Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "SPIRE server StatefulSet Ready replicas. Expected: 1. If 0, identity issuance is broken — cilium-agent's mTLS admin socket will be absent and 'SPIRE Delegate API Client failed to init watcher' warnings will pile up every ~10s.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "kube_statefulset_status_replicas_ready{statefulset=\"spire-server\",namespace=\"cilium-spire\"}", "legendFormat": "spire-server Ready"}
      ],
      "title": "SPIRE Server Ready",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "SPIRE agent DaemonSet ready pods. Expected: 5 (one per node). A gap here means workloads on some nodes cannot get SVIDs and cilium mesh-auth will fail for traffic to/from those nodes.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 4}, {"color": "green", "value": 5}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "kube_daemonset_status_number_ready{daemonset=\"spire-agent\",namespace=\"cilium-spire\"}", "legendFormat": "spire-agent Ready"}
      ],
      "title": "SPIRE Agents Ready (per node)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Gap between desired and ready spire-agent pods. Expected 0. Any non-zero means at least one node has no SPIRE identity provider.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "kube_daemonset_status_desired_number_scheduled{daemonset=\"spire-agent\",namespace=\"cilium-spire\"} - kube_daemonset_status_number_ready{daemonset=\"spire-agent\",namespace=\"cilium-spire\"}", "legendFormat": "Coverage Gap"}
      ],
      "title": "SPIRE Agent Coverage Gap",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "loki-v2"},
      "description": "Count of cilium-agent SPIRE socket warnings over last 1h. 5 cilium-agent pods × 6/min = ~1800/h when SPIRE is consistently broken. >1000/h = chronic flapping. 0 = healthy.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "orange", "value": 500}, {"color": "red", "value": 1000}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"datasource": {"type": "loki", "uid": "loki-v2"}, "expr": "sum(count_over_time({namespace=\"kube-system\",app=\"cilium\"} |~ \"SPIRE.*failed to init\" [1h]))", "legendFormat": "SPIRE Warnings 1h"}
      ],
      "title": "Cilium SPIRE Warnings (1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "panels": [],
      "title": "SPIRE Socket Warning Trend (Loki)",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "loki-v2"},
      "description": "Rate (lines/sec) of cilium-agent SPIRE warning lines, broken out per pod. A flat line at ~0.1/sec per pod = chronic absence. Drops to 0 = SPIRE socket reappeared. Sudden spikes during meltdown windows = supporting evidence that mesh-auth is involved in the cascade.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": false},
          "unit": "cps"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 6},
      "id": 5,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"datasource": {"type": "loki", "uid": "loki-v2"}, "expr": "sum by (pod) (rate({namespace=\"kube-system\",app=\"cilium\"} |~ \"SPIRE.*failed to init\" [5m]))", "legendFormat": "{{pod}}"}
      ],
      "title": "Cilium SPIRE Init-Watcher Warning Rate (per pod)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 102,
      "panels": [],
      "title": "Cilium Mesh-Auth Metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "All cilium-agent metrics that match 'mesh_auth' or 'mutual_auth'. If none of these exist after import time, cilium's mesh-auth subsystem is not emitting metrics (Cilium may have skipped registering them when SPIRE init failed). If they exist with rising error counts, that confirms the suspect.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 6,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum by (__name__) (rate({__name__=~\"cilium_(mesh|mutual)_auth.*\"}[5m]))", "legendFormat": "{{__name__}}"}
      ],
      "title": "Cilium mesh-auth Metric Rates",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "cilium-agent restart rate per pod (restarts/min). Overlay this against the SPIRE warning rate panel — if restart spikes coincide with SPIRE warning rate going to 0 (socket briefly disappeared then came back via pod restart), that's strong evidence the mesh-auth I/O stall is causing the agent to fail liveness.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
          "unit": "cpm"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 7,
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(kube_pod_container_status_restarts_total{namespace=\"kube-system\",container=\"cilium-agent\"}[5m]) * 60", "legendFormat": "{{pod}}"}
      ],
      "title": "Cilium Agent Restart Rate (overlay with SPIRE warnings)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "id": 103,
      "panels": [],
      "title": "Recent SPIRE-related Log Lines",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "loki-v2"},
      "description": "Recent cilium-agent log lines mentioning SPIRE/auth. Use this for quick triage when an SPIRE alert fires.",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 24},
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {"datasource": {"type": "loki", "uid": "loki-v2"}, "expr": "{namespace=\"kube-system\",app=\"cilium\"} |~ \"(?i)(spire|mesh-auth|mutual.*auth)\""}
      ],
      "title": "Cilium Agent SPIRE/Auth Logs",
      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "loki-v2"},
      "description": "Recent spire-server pod logs. Look here to understand why spire-server is 0/1 (PVC binding? cert issue? config error?).",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 24},
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {"datasource": {"type": "loki", "uid": "loki-v2"}, "expr": "{namespace=\"cilium-spire\"}"}
      ],
      "title": "SPIRE Namespace Logs (server + agents)",
      "type": "logs"
    }
  ],
