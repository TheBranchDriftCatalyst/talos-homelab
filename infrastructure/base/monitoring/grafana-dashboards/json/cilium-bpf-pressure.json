  "description": "Cilium BPF map pressure investigation dashboard. Built 2026-05-30 to root-cause whether the recurring cluster meltdowns are driven by BPF map exhaustion (policy/LB/CT maps filling, bpf_update_elem returning -ENOSPC, silent endpoint regeneration failures). Companion to PrometheusRule cilium-bpf-alerts and scripts/test-suspect-bpf-map-pressure.sh.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "tags": [], "targetBlank": true, "title": "Cilium troubleshooting: policymap pressure", "type": "link", "url": "https://docs.cilium.io/en/stable/operations/troubleshooting/#policymap-pressure-and-overflow"},
    {"asDropdown": false, "icon": "external link", "tags": [], "targetBlank": true, "title": "Test script", "type": "link", "url": "https://github.com/TheBranchDriftCatalyst/talos-homelab/blob/main/scripts/test-suspect-bpf-map-pressure.sh"}
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
