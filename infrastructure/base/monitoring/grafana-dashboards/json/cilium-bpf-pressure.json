        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum by (node, map_name, operation) (rate(cilium_bpf_map_ops_total{outcome!=\"success\"}[5m]))", "legendFormat": "{{node}} / {{map_name}} / {{operation}}"}
      ],
      "title": "BPF map insert error rate (per node/map/op)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Number of policies imported (gauge), policy import failures (counter), policy enforcement status. Climbing import errors = downstream of policy map saturation.",
      "fieldConfig": {
