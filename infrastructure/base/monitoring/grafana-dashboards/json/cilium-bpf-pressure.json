    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Rate of failed BPF map insertions per node, per map, per operation. Any nonzero value is a real failure — this is the canary signal that a map just overflowed. Correlate spikes with cilium-agent restart annotations above.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "showPoints": "always"},
