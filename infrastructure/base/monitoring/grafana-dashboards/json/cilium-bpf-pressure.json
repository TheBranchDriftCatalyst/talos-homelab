      "id": 100,
      "panels": [],
      "title": "Cluster-wide BPF Map Pressure",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Most-pressured BPF map across the entire cluster. Green <70%, Yellow 70-89%, Red >=90%. >=90% means we're at the same failure mode as 2026-05-21.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.9}]},
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "max(cilium_bpf_map_pressure)", "legendFormat": "max pressure"}
      ],
      "title": "Cluster max BPF map pressure",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Sum of nonzero rates of cilium_bpf_map_ops_total with outcome!=success across all agents. Any value >0 means a BPF map insert just failed — same kind of error as 'no space left on device' from 2026-05-21.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.001}]},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(cilium_bpf_map_ops_total{outcome!=\"success\"}[5m]))", "legendFormat": "insert errors/s"}
      ],
      "title": "BPF insert error rate (cluster)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Rate of cilium_policy_import_errors_total summed across nodes. Often the downstream symptom of policy map pressure — agent receives a CNP but can't materialize it into BPF.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.001}, {"color": "red", "value": 0.01}]},
          "unit": "ops"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(cilium_policy_import_errors_total[10m]))", "legendFormat": "policy import errors/s"}
      ],
      "title": "Policy import error rate (cluster)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Total identities Cilium has minted. Per-endpoint policy maps scale with identity count. Useful as a leading indicator: rising identity count means rising policy map utilization.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 500}, {"color": "red", "value": 2000}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value"
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "max(cilium_identity)", "legendFormat": "identities"}
      ],
      "title": "Identity count (max across nodes)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 200,
      "panels": [],
      "title": "Per-Map Pressure (table + timeseries)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Heatmap-style view: each map's current utilization, per node. Rows colored by % (Green/Yellow/Red). Sort to find the worst offenders.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "left", "displayMode": "color-background-solid"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.9}]},
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]},
          {"matcher": {"id": "byName", "options": "node"}, "properties": [{"id": "custom.width", "value": 120}, {"id": "custom.displayMode", "value": "auto"}]},
          {"matcher": {"id": "byName", "options": "map_name"}, "properties": [{"id": "custom.width", "value": 350}, {"id": "custom.displayMode", "value": "auto"}]}
        ]
      },
      "gridPos": {"h": 14, "w": 12, "x": 0, "y": 7},
      "id": 5,
      "options": {
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Value"}]
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "max by (node, map_name) (cilium_bpf_map_pressure)", "format": "table", "instant": true, "refId": "A"}
      ],
      "title": "Per-map pressure (sorted)",
      "type": "table",
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "pod": true, "namespace": true, "cluster": true, "container": true}, "renameByName": {"Value": "Pressure"}}}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Time series of policy map pressure per node. Watch for sustained climb between cilium-agent restarts — that pattern is the smoking gun for the BPF-exhaustion hypothesis.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.9}]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
