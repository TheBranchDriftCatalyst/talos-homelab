      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum by (node) (cilium_policy)", "legendFormat": "policies imported — {{node}}"},
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum by (node) (rate(cilium_policy_import_errors_total[5m]))", "legendFormat": "import errors/s — {{node}}"}
      ],
      "title": "Policy import: count + error rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "description": "Cilium identity count + endpoint count over time. Identity count drives per-endpoint policy map size. Sustained growth = future policy map pressure.",
