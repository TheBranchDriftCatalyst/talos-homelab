        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "max by (node) (cilium_bpf_map_pressure{map_name=~\"cilium_policy.*|cilium_call_policy\"})", "legendFormat": "policy pressure — {{node}}"},
        {"datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum by (node) (kube_pod_container_status_restarts_total{namespace=\"kube-system\",container=\"cilium-agent\"})", "legendFormat": "cumulative restarts — {{node}}"}
      ],
      "title": "Policy pressure vs cilium-agent restarts (correlation)",
