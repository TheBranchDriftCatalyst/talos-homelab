{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticPrefixFixDepsChoreOthers",
    "schedule:weekly"
  ],
  "timezone": "America/Los_Angeles",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 0,
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Group ALL non-major updates into a single weekly PR (no more one-PR-per-package spam)",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "automerge": true
    },
    {
      "description": "Group all GitHub Actions bumps into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "description": "Group all Docker/container image bumps into one PR",
      "matchDatasources": ["docker"],
      "groupName": "container images",
      "automerge": true
    },
    {
      "description": "Isolate major updates so each gets its own review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    }
  ]
}
